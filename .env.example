# ===========================================
# FireTrain 项目环境变量配置
# ===========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置值
# 3. 不要将 .env 提交到版本控制系统

# ===========================================
# 数据库配置
# ===========================================
# 本地开发使用 SQLite（推荐）
DATABASE_URL=sqlite:///./fire_training.db

# MySQL 配置（联调和生产环境使用）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=firetrain
MYSQL_PASSWORD=firetrain
MYSQL_DATABASE=fire_training

# ===========================================
# JWT 认证配置
# ===========================================
# 注意：生产环境请修改为强随机密钥
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# 服务端口配置
# ===========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# API 基础 URL（前端使用）
VITE_API_BASE_URL=http://localhost:8000/api

# ===========================================
# AI 模型路径配置
# ===========================================
MODEL_PATH=./data/models
VIDEO_PATH=./data/videos

# YOLOv8 模型配置
YOLO_MODEL_NAME=yolov8n.pt
YOLO_CONF_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45

# MediaPipe 配置
MEDIAPIPE_MODEL_COMPLEXITY=1
MEDIAPIPE_SMOOTH_LANDMARKS=true

# ===========================================
# 评分规则配置
# ===========================================
# 灭火器操作步骤权重
STEP_WEIGHT_LIFT=0.2        # 提灭火器
STEP_WEIGHT_PULL=0.2        # 拔保险销
STEP_WEIGHT_HOLD=0.15       # 握喷管
STEP_WEIGHT_AIM=0.2         # 瞄准火源
STEP_WEIGHT_PRESS=0.25      # 压把手

# 动作判定阈值
ANGLE_THRESHOLD_ARM=90      # 手臂角度阈值（度）
DISTANCE_THRESHOLD=1.5      # 距离阈值（米）
TIME_LIMIT_TOTAL=60         # 总时间限制（秒）

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=./logs/firetrain.log

# ===========================================
# CORS 跨域配置
# ===========================================
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ===========================================
# Docker 配置（可选）
# ===========================================
DOCKER_MYSQL_IMAGE=mysql:8.0
DOCKER_PYTHON_IMAGE=python:3.10-slim
DOCKER_NODE_IMAGE=node:20-alpine

# ===========================================
# 其他配置
# ===========================================
DEBUG=true
ENVIRONMENT=development
MAX_UPLOAD_SIZE=100MB
ALLOWED_VIDEO_TYPES=mp4,avi,mov,wmv
